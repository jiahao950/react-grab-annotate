{
  "name": "@react-grab/annotate-server",
  "version": "0.1.47",
  "private": true,
  "description": "Local API server that persists react-grab annotations (screenshot + source location + comment) to disk for AI consumption",
  "license": "MIT",
  "bin": {
    "react-grab-annotate-server": "./bin/server.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "vp pack",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.20"
  }
}
