{
  "name": "react-grab-annotate",
  "version": "0.1.24",
  "description": "Annotate a running React app in the browser (screenshot + source location + comment) and save it to disk for an AI coding agent to read.",
  "keywords": [
    "agent",
    "ai",
    "annotate",
    "annotation",
    "devtool",
    "react",
    "react-grab"
  ],
  "license": "MIT",
  "bin": {
    "react-grab-annotate": "./bin/server.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/server.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.mjs && tsc -p tsconfig.build.json",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "esbuild": "^0.25.12",
    "react": "19.2.6",
    "react-grab": "workspace:*",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
